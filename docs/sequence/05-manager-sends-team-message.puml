@startuml
title Менеджер отправляет сообщение в чат команды

autonumber
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true

actor "Менеджер" as manager
participant "Admin UI" as ui
participant "Support Admin API" as api
database "public.managers" as managers
database "public.team_messages" as team_messages
database "public.team_read_states" as team_read_states
participant "Supabase Realtime" as realtime
participant "Другой менеджер" as other_manager

manager -> ui : Открывает «Чат команды»
ui -> api : POST /api/team-messages\ntext
api -> managers : Определяет текущего менеджера\nпо auth session
managers --> api : Менеджер найден
api -> team_messages : INSERT\nsender_id, text, created_at
team_messages --> api : Сообщение сохранено
api --> ui : 200 OK

team_messages -> realtime : WAL change event
realtime -> ui : postgres_changes event\n(table = team_messages)
ui -> ui : router.refresh()\nперечитывает team_messages

realtime -> other_manager : postgres_changes event\nчерез WebSocket
other_manager -> other_manager : Обновляет unread count\nв сайдбаре

ui -> api : POST /api/team-messages/read\nmessageId = last message id
api -> team_read_states : UPSERT\nmanager_id, last_read_message_id,\nupdated_at
api --> ui : 200 OK
ui -> ui : router.refresh()\nсбрасывает unread badge

@enduml
