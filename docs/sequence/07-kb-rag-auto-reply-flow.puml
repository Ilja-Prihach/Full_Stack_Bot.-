@startuml
title Auto-reply через Knowledge Base + RAG

autonumber
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true

actor "Пользователь Telegram" as tg_user
participant "Telegram" as telegram
participant "telegram-webhook" as webhook
database "public.clients" as clients
database "public.messages" as messages
database "public.client_assignments" as assignments
database "public.ai_daily_usage" as daily_usage
database "public.ai_reply_events" as reply_events
participant "webhook handlers.ts" as handlers
participant "webhook ai.ts" as ai_layer
database "public.kb_entries" as kb_entries
database "public.kb_embeddings" as kb_embeddings
participant "OpenAI API" as openai
participant "Admin UI" as ui
participant "Support Admin KB API" as kb_api

tg_user -> telegram : Отправляет сообщение в бот
telegram -> webhook : Webhook update\nchat, user, text

webhook -> clients : Ищет или создаёт клиента
clients --> webhook : client_id
webhook -> assignments : Читает ai_auto_reply_enabled\nи workflow_status
assignments --> webhook : Текущее состояние клиента

webhook -> messages : Сохраняет входящее сообщение\nsender_type = client
messages --> webhook : source_message_id
webhook -> assignments : Обновляет\nlast_client_message_at = now()

alt Статус был completed
  webhook -> assignments : completed -> new
end

alt AI выключен по workflow_status или manual toggle
  webhook --> telegram : 200 OK без авто-ответа
else AI разрешён
  webhook -> handlers : handleIncomingTextMessage(...)

  alt Сообщение не текстовое
    handlers -> reply_events : Пишет событие\nreply_type = none\ndecision = ignored_non_text
    webhook --> telegram : 200 OK без ответа
  else Текстовое сообщение
    handlers -> handlers : Проверка длины,\nлимитов и canned intents

    alt Greeting или canned reply распознан
      handlers -> daily_usage : Проверяет usage за сегодня
      daily_usage --> handlers : reply_count
      handlers -> telegram : Отправляет canned reply
      handlers -> messages : Сохраняет ответ\nsender_type = ai_bot
      handlers -> daily_usage : Увеличивает reply_count
      handlers -> reply_events : Пишет событие\nнапример greeting_sent,\nmanager_request_sent,\nurgency_sent
      webhook --> telegram : 200 OK
    else Нужен KB + RAG путь
      handlers -> ai_layer : generateAutoReply(messageText)

      ai_layer -> openai : Создаёт embedding вопроса
      openai --> ai_layer : query_embedding

      ai_layer -> kb_embeddings : RPC match_kb_entries\nпо query_embedding
      kb_embeddings --> ai_layer : candidate kb_entry_id + similarity
      ai_layer -> kb_entries : Загружает статьи\nпо matched ids
      kb_entries --> ai_layer : Контекст для ответа

      alt Лучший match ниже порога
        ai_layer --> handlers : shouldReply = false\nreason = no_match
      else Match найден
        ai_layer -> openai : Форматирует KB-ответ\nчерез Responses API
        openai --> ai_layer : answer
        ai_layer --> handlers : shouldReply = true\nanswer, confidence,\nmatchedEntryIds,\nreason = match_found
      end

      alt shouldReply = true
        handlers -> telegram : Отправляет AI-ответ
        handlers -> messages : Сохраняет ответ\nsender_type = ai_bot
        handlers -> daily_usage : Увеличивает reply_count
        handlers -> reply_events : Пишет событие\nconfidence, matchedEntryIds,\ndecision = match_found
      else shouldReply = false
        handlers -> telegram : Отправляет fallback\n"Запрос передан менеджеру"
        handlers -> reply_events : Пишет событие\nconfidence, decision = no_match
      end

      webhook --> telegram : 200 OK
    end
  end
end

== Управление базой знаний ==

ui -> kb_api : POST /api/kb/reindex\nили create/update entry
kb_api -> kb_entries : Читает активные статьи\nили сохраняет изменения
kb_entries --> kb_api : Статьи готовы к индексации
kb_api -> openai : Создаёт embedding статьи
openai --> kb_api : embedding
kb_api -> kb_embeddings : Сохраняет embedding
kb_api -> kb_entries : Обновляет status\nembedding_ready / embedding_failed

== Отображение в админке ==

ui -> messages : Запрашивает историю чата
messages --> ui : client + manager + ai_bot сообщения
ui -> assignments : Запрашивает workflow_status,\npriority, assignee и AI toggle
assignments --> ui : Operational state клиента

@enduml
