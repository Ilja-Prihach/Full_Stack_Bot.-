@startuml
title SupportBot Supabase ERD

left to right direction
hide circle

skinparam shadowing false
skinparam linetype ortho
skinparam nodesep 140
skinparam ranksep 150
skinparam entity {
  BackgroundColor white
  BorderColor black
}

entity "auth.users" as auth_users {
  * id : uuid <<PK>>
  --
  email : text
  created_at : timestamptz
}

entity "public.managers" as managers {
  * id : bigint <<PK>>
  --
  * auth_user_id : uuid <<FK, UNIQUE>>
  * email : text <<UNIQUE>>
  * first_name : varchar(255)
  * last_name : varchar(255)
  * position : varchar(255)
  * created_at : timestamptz = now()
}

entity "public.clients" as clients {
  * id : bigint <<PK>>
  --
  * telegram_user_id : bigint <<UNIQUE>>
  * telegram_chat_id : bigint <<UNIQUE>>
  username : varchar(32)
  first_name : varchar(64)
  last_name : varchar(64)
  * created_at : timestamptz = now()
}

entity "public.client_assignments" as client_assignments {
  * id : bigint <<PK>>
  --
  * client_id : bigint <<FK, UNIQUE>>
  assigned_manager_id : bigint <<FK>>
  previous_manager_id : bigint <<FK>>
  last_reassigned_by_manager_id : bigint <<FK>>
  last_reassigned_by_manager_name : varchar(255)
  * created_at : timestamptz = now()
  updated_at : timestamptz
}

entity "public.messages" as messages {
  * id : bigint <<PK>>
  --
  chat_id : bigint <<LEGACY>>
  user_id : bigint <<LEGACY>>
  username : varchar(255) <<LEGACY>>
  first_name : varchar(255) <<LEGACY>>
  last_name : varchar(255) <<LEGACY>>
  * client_id : bigint <<FK>>
  * sender_type : text
  sender_manager_id : bigint <<FK>>
  * sender_label : varchar(255)
  * text : text
  * created_at : timestamptz = now()
}

entity "public.client_read_states" as client_read_states {
  * id : bigint <<PK>>
  --
  * client_id : bigint <<FK>>
  * manager_id : bigint <<FK>>
  last_read_message_id : bigint <<FK>>
  last_read_at : timestamptz
  * created_at : timestamptz = now()
  * updated_at : timestamptz = now()
  <<UNIQUE (client_id, manager_id)>>
}

entity "public.team_messages" as team_messages {
  * id : bigint <<PK>>
  --
  * sender_id : bigint <<FK>>
  * text : text
  * created_at : timestamptz = now()
}

entity "public.team_read_states" as team_read_states {
  * id : bigint <<PK>>
  --
  * manager_id : bigint <<FK, UNIQUE>>
  last_read_message_id : bigint <<FK>>
  * updated_at : timestamptz = now()
}

auth_users ||--o{ managers : "auth user"
clients ||--|| client_assignments : "assignment"
clients ||--o{ messages : "messages"
clients ||--o{ client_read_states : "read states"
managers ||--o{ client_assignments : "current manager"
managers ||--o{ client_assignments : "previous manager"
managers ||--o{ client_assignments : "reassigned by"
managers ||--o{ messages : "manager sender"
managers ||--o{ client_read_states : "read by manager"
managers ||--o{ team_messages : "sender"
managers ||--o{ team_read_states : "read state"

note right of messages
  Client support messages.
  Supports both client and
  manager messages via sender_type.
  Legacy columns kept for transition.
  RLS enabled, manager-only access.
  Realtime publication enabled.
end note

note right of team_messages
  Internal team chat between
  all managers. No client linkage.
  RLS enabled, manager-only access.
  Realtime publication enabled.
end note

note right of client_read_states
  Tracks last read message
  per client per manager.
  Used for unread counts in sidebar.
end note

note right of team_read_states
  Tracks last read team message
  per manager.
  One row per manager.
end note

@enduml
