@startuml
title SupportBot - Container Diagram

left to right direction
skinparam shadowing false
skinparam nodesep 90
skinparam ranksep 100
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam defaultTextAlignment center
skinparam ArrowColor #4b5563
skinparam ArrowThickness 1.2
skinparam RectangleBorderColor #1f2937
skinparam RectangleBackgroundColor #f8fafc
skinparam PackageBorderColor #1f2937
skinparam PackageBackgroundColor #eef2ff
skinparam DatabaseBorderColor #1f2937
skinparam DatabaseBackgroundColor #ecfeff
skinparam ActorBorderColor #1f2937
skinparam ActorBackgroundColor #fef3c7

actor "Telegram User" as TelegramUser
actor "Support Manager" as SupportManager
rectangle "Telegram Bot API" as TelegramApi
rectangle "Browser" as Browser
rectangle "Supabase Realtime\nWebSocket transport" as Realtime
rectangle "OpenAI API" as OpenAiApi

package "SupportBot Containers" as SupportBot {
  package "support-admin" as SupportAdminBoundary {
    rectangle "Next.js page renderer\nsrc/app/page.tsx" as NextPage
    rectangle "Admin dashboard UI\nchat workspace + KB workspace" as DashboardUi
    rectangle "Chat API routes\nreply, assignment,\nworkflow status,\npriority, ai toggle,\nread, team chat,\nmanager status" as ChatRoutes
    rectangle "Knowledge Base API routes\n/api/kb/categories,\n/api/kb/entries,\n/api/kb/reindex" as KbRoutes
    rectangle "Supabase JS clients\nSSR + browser realtime" as AdminSupabaseClient
  }

  package "Supabase Project" as SupabaseBoundary {
    rectangle "telegram-webhook\nDeno HTTP function" as Webhook
    rectangle "Webhook AI layer\nhandlers.ts + ai.ts + messages.ts" as WebhookAi
    database "Postgres tables\nmessages, clients,\nclient assignments,\nteam chat, statuses,\nread states, KB,\nai usage, ai events" as SupportDb
  }
}

SupportManager --> Browser : uses
Browser --> NextPage : requests admin page
NextPage --> AdminSupabaseClient : creates query client
NextPage --> SupportDb : selects messages,\nteam messages, managers,\nmanager statuses, assignments,\nworkflow status, effective priority\nand read states
NextPage --> DashboardUi : passes initial data\nand auth token

DashboardUi --> AdminSupabaseClient : subscribes to\nrealtime changes
AdminSupabaseClient --> Realtime : opens authenticated\nWebSocket subscription
Realtime --> DashboardUi : notifies about\nmessages, assignments,\nteam chat and manager status changes

DashboardUi --> ChatRoutes : sends chat actions
ChatRoutes --> SupportDb : inserts and updates\nchat-related data,\nworkflow status,\nAI toggle and\nmanual priority override

DashboardUi --> KbRoutes : creates, edits,\nreads, reindexes and\ndeletes KB data
KbRoutes --> SupportDb : reads and writes\nkb_categories, kb_entries\nand kb_embeddings
KbRoutes --> OpenAiApi : creates KB embeddings

TelegramUser --> TelegramApi : sends message
TelegramApi --> Webhook : POST update payload
Webhook --> SupportDb : upserts client,\ninserts inbound message,\nupdates last_client_message_at,\nreads assignment state
Webhook --> WebhookAi : handles canned replies\nor KB + RAG generation
WebhookAi --> OpenAiApi : creates question embedding\nand formats answer
WebhookAi --> SupportDb : rpc(match_kb_entries)\nand reads KB entries
Webhook --> SupportDb : inserts ai_bot message,\nai_daily_usage,\nai_reply_events,\nupdates workflow status
Webhook --> TelegramApi : POST sendMessage\nfor greeting, answer or fallback

AdminSupabaseClient --> SupportDb : connects with\nmanager session / anon key
ChatRoutes --> SupportDb : connects with\nmanager session
KbRoutes --> SupportDb : connects with\nmanager session

@enduml
