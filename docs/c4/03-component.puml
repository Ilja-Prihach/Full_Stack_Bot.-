@startuml
title SupportBot - Component Diagram

left to right direction
skinparam shadowing false
skinparam nodesep 90
skinparam ranksep 110
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam defaultTextAlignment center
skinparam ArrowColor #4b5563
skinparam ArrowThickness 1.2
skinparam RectangleBorderColor #1f2937
skinparam RectangleBackgroundColor #f8fafc
skinparam PackageBorderColor #1f2937
skinparam PackageBackgroundColor #eef2ff
skinparam DatabaseBorderColor #1f2937
skinparam DatabaseBackgroundColor #ecfeff
skinparam ActorBorderColor #1f2937
skinparam ActorBackgroundColor #fef3c7

actor "Support Manager" as SupportManager
rectangle "Browser" as Browser
rectangle "Telegram Bot API" as TelegramApi
rectangle "Supabase Realtime\nWebSocket" as Realtime
database "Supabase Postgres\nmessages, clients,\nmanagers, client_assignments" as MessagesDb

package "support-admin" as SupportAdmin {
  rectangle "page.tsx\nSSR entrypoint" as Page
  rectangle "supabase.ts\nSSR client + browser realtime" as FrontSupabase
  rectangle "AdminDashboard\nsearch, selection,\nrealtime refresh, theme" as AdminDashboard
  rectangle "dashboard-shared\nformat helpers,\nchat previews, types" as DashboardShared
  rectangle "DashboardHero\nsummary header" as DashboardHero
  rectangle "ChatSidebar\nchat list, search,\nmanual refresh" as ChatSidebar
  rectangle "MessagePanel\ndialog transcript,\ncomposer, send on Enter" as MessagePanel
  rectangle "reply route\n/api/clients/[clientId]/messages" as ReplyRoute
}

package "telegram-webhook" as TelegramWebhook {
  rectangle "index.ts\nHTTP entrypoint" as WebhookIndex
  rectangle "handlers.ts\n/start and inbound\nmessage flow" as WebhookHandlers
  rectangle "telegram.ts\nupdate parsing,\nsendMessage wrapper" as WebhookTelegram
  rectangle "messages.ts\nfindOrCreateClient,\ninsert inbound message" as WebhookMessages
  rectangle "config.ts\nenvironment variables" as WebhookConfig
}

SupportManager -[hidden]-> Browser
Browser -[hidden]-> Page
Page -[hidden]-> FrontSupabase
FrontSupabase -[hidden]-> MessagesDb
FrontSupabase -[hidden]-> Realtime
Page -[hidden]-> AdminDashboard
AdminDashboard -[hidden]-> DashboardHero
AdminDashboard -[hidden]-> ChatSidebar
AdminDashboard -[hidden]-> MessagePanel
ChatSidebar -[hidden]-> DashboardShared
MessagePanel -[hidden]-> DashboardShared
MessagePanel -[hidden]-> ReplyRoute
TelegramApi -[hidden]-> WebhookIndex
WebhookIndex -[hidden]-> WebhookHandlers
WebhookHandlers -[hidden]-> WebhookMessages
WebhookMessages -[hidden]-> WebhookConfig
WebhookConfig -[hidden]-> WebhookTelegram

SupportManager --> Browser : uses
Browser --> Page : requests /
Page --> FrontSupabase : imports client
Page --> MessagesDb : selects messages,\nclients and managers
Page --> AdminDashboard : passes initial data,\nmanager profile and access token

AdminDashboard --> DashboardHero : renders stats
AdminDashboard --> ChatSidebar : renders chat navigation
AdminDashboard --> MessagePanel : renders selected chat
AdminDashboard --> DashboardShared : preview and\nlabel helpers
AdminDashboard --> FrontSupabase : opens realtime\nmessages subscription
FrontSupabase --> Realtime : authenticated WebSocket
Realtime --> AdminDashboard : messages change event
ChatSidebar --> DashboardShared : formatTime
MessagePanel --> DashboardShared : format and\nlabel helpers
ChatSidebar --> Page : triggers manual\nrouter.refresh
MessagePanel --> ReplyRoute : POST reply text
ReplyRoute --> TelegramApi : POST /sendMessage
ReplyRoute --> MessagesDb : insert manager message

TelegramApi --> WebhookIndex : POST update
WebhookIndex --> WebhookTelegram : extractTelegramMessage(update)
WebhookIndex --> WebhookHandlers : dispatches /start\nor text flow
WebhookHandlers --> WebhookConfig : validates env presence
WebhookHandlers --> WebhookMessages : saveIncomingMessage(...)
WebhookHandlers --> WebhookTelegram : sendTelegramMessage(...)\nwhen auto-reply is needed
WebhookMessages --> WebhookConfig : reads Supabase URL\nand service key
WebhookMessages --> MessagesDb : upsert client and\ninsert inbound row
WebhookTelegram --> WebhookConfig : reads bot token
WebhookTelegram --> TelegramApi : POST /sendMessage

@enduml
