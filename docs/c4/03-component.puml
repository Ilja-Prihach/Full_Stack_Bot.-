@startuml
title SupportBot - Component Diagram

left to right direction
skinparam shadowing false
skinparam nodesep 90
skinparam ranksep 110
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam defaultTextAlignment center
skinparam ArrowColor #4b5563
skinparam ArrowThickness 1.2
skinparam RectangleBorderColor #1f2937
skinparam RectangleBackgroundColor #f8fafc
skinparam PackageBorderColor #1f2937
skinparam PackageBackgroundColor #eef2ff
skinparam DatabaseBorderColor #1f2937
skinparam DatabaseBackgroundColor #ecfeff
skinparam ActorBorderColor #1f2937
skinparam ActorBackgroundColor #fef3c7

actor "Support Manager" as SupportManager
rectangle "Browser" as Browser
rectangle "Telegram Bot API" as TelegramApi
rectangle "Supabase Realtime\nWebSocket" as Realtime
rectangle "OpenAI API" as OpenAiApi
database "Supabase Postgres\nchat tables + KB + AI tables" as SupportDb

package "support-admin" as SupportAdmin {
  rectangle "page.tsx\nSSR entrypoint" as Page
  rectangle "supabase.ts\nSSR client + browser realtime" as FrontSupabase
  rectangle "AdminDashboard\nchat shell, selection,\nrealtime refresh,\nfilters and workspace switching" as AdminDashboard
  rectangle "KnowledgeBase\nKB workspace UI" as KnowledgeBaseUi
  rectangle "dashboard-shared\ntypes, preview sorting,\npriority/status helpers" as DashboardShared
  rectangle "DashboardHero\nheader, manager status,\nKB toggle" as DashboardHero
  rectangle "ChatSidebar\nchat navigation,\nstatus/priority badges,\nfilters" as ChatSidebar
  rectangle "MessagePanel\ntranscript,\nworkflow controls,\nmanual priority,\nassignment, AI toggle,\ncomposer, read tracking" as MessagePanel
  rectangle "Chat API routes\nreply, assignment,\nworkflow status,\npriority, ai toggle,\nread, team chat,\nmanager status" as ChatRoutes
  rectangle "KB API routes\n/api/kb/categories,\n/api/kb/entries,\n[id] PATCH/DELETE,\n/api/kb/reindex" as KbRoutes
  rectangle "kb-embeddings.ts\nreindex + embedding helpers" as KbEmbeddings
}

package "telegram-webhook" as TelegramWebhook {
  rectangle "index.ts\nHTTP entrypoint" as WebhookIndex
  rectangle "handlers.ts\npre-checks, canned replies,\nlimits, fallback,\nRAG routing" as WebhookHandlers
  rectangle "ai.ts\nKB search,\nOpenAI embedding,\nanswer formatting" as WebhookAi
  rectangle "telegram.ts\nupdate parsing,\nsendMessage wrapper" as WebhookTelegram
  rectangle "messages.ts\nclient lookup,\nmessage insert,\nworkflow state,\nai usage and events" as WebhookMessages
  rectangle "config.ts\nenvironment variables" as WebhookConfig
}

SupportManager --> Browser : uses
Browser --> Page : requests /
Page --> FrontSupabase : imports client
Page --> SupportDb : selects chat data,\nworkflow status,\npriority_mode,\nmanual_priority_label,\npriority score and read states
Page --> AdminDashboard : passes initial data\nand access token

AdminDashboard --> DashboardHero : renders header
AdminDashboard --> ChatSidebar : renders chat navigation
AdminDashboard --> MessagePanel : renders selected chat
AdminDashboard --> KnowledgeBaseUi : renders KB workspace
AdminDashboard --> DashboardShared : preview and label helpers
AdminDashboard --> FrontSupabase : opens realtime\nsubscriptions
FrontSupabase --> Realtime : authenticated WebSocket
Realtime --> AdminDashboard : postgres_changes and\npresence sync events

MessagePanel --> DashboardShared : effective priority,\nlabels and timestamps
MessagePanel --> ChatRoutes : sends chat actions
DashboardHero --> ChatRoutes : sends manager status update
ChatRoutes --> SupportDb : reads and writes\nchat-related tables,\nworkflow status,\nAI toggle and\nmanual priority override

KnowledgeBaseUi --> KbRoutes : GET/POST/PATCH/DELETE\nKB data and reindex
KbRoutes --> KbEmbeddings : reindex embeddings
KbRoutes --> SupportDb : reads and writes\nkb_categories and kb_entries
KbEmbeddings --> OpenAiApi : creates article embeddings
KbEmbeddings --> SupportDb : writes kb_embeddings\nand KB status

TelegramApi --> WebhookIndex : POST update
WebhookIndex --> WebhookTelegram : extractTelegramMessage(update)
WebhookIndex --> WebhookHandlers : dispatch inbound flow
WebhookHandlers --> WebhookConfig : validates env presence
WebhookHandlers --> WebhookMessages : saveIncomingMessage,\ngetTodayAiReplyCount,\ngetLastAiReplyAt,\nsaveAiReplyEvent,\nsaveAiBotMessage
WebhookHandlers --> WebhookAi : generateAutoReply(messageText)
WebhookHandlers --> WebhookTelegram : sendTelegramMessage(...)
WebhookMessages --> SupportDb : reads and writes\nclients, messages,\nclient_assignments,\nai_daily_usage,\nai_reply_events
WebhookAi --> OpenAiApi : embeddings + responses
WebhookAi --> SupportDb : rpc(match_kb_entries)\nand reads KB entries
WebhookTelegram --> TelegramApi : POST /sendMessage

@enduml
