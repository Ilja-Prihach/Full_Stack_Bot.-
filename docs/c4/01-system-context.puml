@startuml
title SupportBot - System Context

left to right direction
skinparam shadowing false
skinparam nodesep 80
skinparam ranksep 90
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam defaultTextAlignment center
skinparam ArrowColor #4b5563
skinparam ArrowThickness 1.2
skinparam RectangleBorderColor #1f2937
skinparam RectangleBackgroundColor #f8fafc
skinparam PackageBorderColor #1f2937
skinparam PackageBackgroundColor #eef2ff
skinparam DatabaseBorderColor #1f2937
skinparam DatabaseBackgroundColor #ecfeff
skinparam ActorBorderColor #1f2937
skinparam ActorBackgroundColor #fef3c7

actor "Telegram User" as TelegramUser
actor "Support Manager" as SupportManager
rectangle "Telegram Bot API" as TelegramApi
rectangle "Supabase Realtime\nWebSocket" as SupabaseRealtime

package "SupportBot" as SupportBot {
  rectangle "support-admin\nNext.js admin dashboard" as SupportAdmin
  rectangle "admin reply API\n/api/clients/{id}/messages" as ReplyApi
  rectangle "manager status API\n/api/manager-status" as ManagerStatusApi
  rectangle "telegram-webhook\nSupabase Edge Function" as TelegramWebhook
  database "Supabase Postgres\nmessages, team_messages,\nmanager_statuses, read states,\nclients, managers, assignments" as MessagesDb
}

rectangle "Supabase Platform" as SupabasePlatform

TelegramUser -[hidden]-> TelegramApi
TelegramApi -[hidden]-> TelegramWebhook
TelegramWebhook -[hidden]-> MessagesDb
SupportManager -[hidden]-> SupportAdmin
SupportAdmin -[hidden]-> ReplyApi
SupportAdmin -[hidden]-> SupabaseRealtime
MessagesDb -[hidden]-> SupabasePlatform

TelegramUser --> TelegramApi : sends\nsupport message
TelegramApi --> TelegramWebhook : forwards\nwebhook update
TelegramWebhook --> MessagesDb : persists inbound\nmessage and client data
TelegramWebhook --> TelegramApi : sends conditional\nacknowledgement

SupportManager --> SupportAdmin : opens dashboard
SupportManager --> ReplyApi : sends reply\nthrough admin UI
SupportManager --> ManagerStatusApi : updates custom\navailability status
SupportAdmin --> MessagesDb : reads dialogs\nand manager data
ReplyApi --> TelegramApi : sends manager\nmessage
ReplyApi --> MessagesDb : stores outgoing\nmanager message
ManagerStatusApi --> MessagesDb : upserts manager\navailability status
MessagesDb --> SupabaseRealtime : emits table\nchange events
SupabaseRealtime --> SupportAdmin : pushes realtime\nupdates over WebSocket

TelegramWebhook --> SupabasePlatform : deployed on
MessagesDb --> SupabasePlatform : hosted by
SupportAdmin --> SupabasePlatform : uses project URL,\nauth session and realtime
ReplyApi --> SupabasePlatform : uses project URL\nand manager session
ManagerStatusApi --> SupabasePlatform : uses project URL\nand manager session

@enduml
